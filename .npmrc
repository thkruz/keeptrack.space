# pnpm configuration
# Flat, npm-like node_modules layout. Chosen for the migration off npm so that
# rspack loaders, babel plugins, and webgl mocks that assume a hoisted tree keep
# resolving. Can be tightened to pnpm's default isolated linker later.
node-linker=hoisted

# Match npm's lenient peer-dependency behavior so installs don't hard-fail on
# peer mismatches that npm previously tolerated.
strict-peer-dependencies=false
auto-install-peers=true

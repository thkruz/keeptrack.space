import { setupStandardEnvironment } from '@test/environment/standard-env';
import { standardPluginSuite } from '@test/generic-tests';
import { vi } from 'vitest';
import { __CLASS_NAME__ } from '../src/plugin';

describe('__CLASS_NAME__', () => {
  beforeEach(() => {
    setupStandardEnvironment();
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  standardPluginSuite(__CLASS_NAME__, '__CONFIG_KEY__');
});

describe('__CLASS_NAME__ behavior', () => {
  let plugin: __CLASS_NAME__;

  beforeEach(() => {
    setupStandardEnvironment();
    plugin = new __CLASS_NAME__();
    plugin.init();
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  it('exposes the bottom icon, help, keyboard shortcut, and command palette', () => {
    expect(plugin.getBottomIconConfig().elementName).toBe('__ELEMENT_BASE__-bottom-icon');
    expect(plugin.getHelpConfig().sections.length).toBeGreaterThan(0);
    expect(plugin.getKeyboardShortcuts().length).toBeGreaterThan(0);
    expect(plugin.getCommandPaletteCommands()[0].id).toBe('__CONFIG_KEY__.toggle');
  });

  it('toggles without throwing when the icon is clicked', () => {
    expect(() => plugin.onBottomIconClick()).not.toThrow();
    expect(() => plugin.onBottomIconClick()).not.toThrow();
  });
});
